<Window x:Class="MovieReporter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Movie Reporter"
        Width="1380"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        Background="#10221F"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F6EFE6" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8C7B3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C96D44" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#8D4A2C" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5E625C" />
        <SolidColorBrush x:Key="TableBrush" Color="#FFFDF9" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#25302F" />
            <Setter Property="Background" Value="#E7DACB" />
            <Setter Property="BorderBrush" Value="#C8B49C" />
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#CDB9A3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FormatCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#25302F" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#25302F" />
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#6C6D68" />
        </Style>

        <Style x:Key="FilterChipCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#5E625C" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="FilterChipBorder"
                                Padding="12,7"
                                Background="#EEE5D7"
                                BorderBrush="#D0C0AA"
                                BorderThickness="1"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="FilterChipBorder" Property="Background" Value="#253F3B" />
                                <Setter TargetName="FilterChipBorder" Property="BorderBrush" Value="#4E726A" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FilterChipBorder" Property="BorderBrush" Value="#9B765D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ResolutionBadgeTemplate">
            <Border Margin="0,0,8,8"
                    Padding="10,4"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999">
                <TextBlock Text="{Binding Label}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{Binding ForegroundBrush}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SeasonInspectionTemplate">
            <Border Margin="0,0,0,12"
                    Padding="14"
                    Background="#FFFDF9"
                    BorderBrush="#D9C8B3"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding SeasonLabel}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#25302F" />

                    <Border Grid.Column="1"
                            Padding="10,4"
                            Background="{Binding StatusBackground}"
                            BorderBrush="{Binding StatusBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding StatusForeground}" />
                    </Border>

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Text="{Binding FoundSummary}"
                               FontSize="12"
                               Foreground="#394443"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4"
                               Grid.ColumnSpan="2"
                               Text="{Binding MissingSummary}"
                               FontSize="12"
                               Foreground="#394443"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="6"
                               Grid.ColumnSpan="2"
                               Text="{Binding DiagnosticsSummary}"
                               FontSize="12"
                               Foreground="#6C6D68"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="26"
                CornerRadius="24"
                BorderThickness="1"
                BorderBrush="#31524D">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#173733" Offset="0" />
                    <GradientStop Color="#2A544A" Offset="0.55" />
                    <GradientStop Color="#9D5A37" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Movie Reporter"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#E8E2D9"
                               Text="Scan a root library that contains Movies and TV Shows, then export the active tab in parallel." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,12"
                        CornerRadius="18"
                        Background="#1E2C2B"
                        BorderBrush="#50736C"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Session Status"
                                   Foreground="#B9C6BF"
                                   FontSize="12" />
                        <TextBlock x:Name="HeaderStatusTextBlock"
                                   Margin="0,4,0,0"
                                   Text="Idle"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="410" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel x:Name="InputPanel">
                            <TextBlock Text="Source Library"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#25302F" />
                            <TextBlock Style="{StaticResource LabelStyle}"
                                       Text="Select the root folder that contains the top-level Movies and TV Shows folders." />
                            <TextBox x:Name="SourceFolderTextBox"
                                     Style="{StaticResource TextInputStyle}" />
                            <Button x:Name="BrowseSourceButton"
                                    Click="BrowseSourceFolderButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse Source Folder" />

                            <Separator Margin="0,22,0,20" />

                            <TextBlock Text="Export Target"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#25302F" />
                            <TextBlock Style="{StaticResource LabelStyle}"
                                       Text="The active result tab is exported. A '-movies' or '-tv-shows' suffix is added automatically." />
                            <TextBox x:Name="OutputFolderTextBox"
                                     Style="{StaticResource TextInputStyle}" />
                            <Button x:Name="BrowseOutputButton"
                                    Click="BrowseOutputFolderButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse Output Folder" />
                            <TextBlock Margin="0,18,0,8"
                                       Style="{StaticResource LabelStyle}"
                                       Text="Export file name" />
                            <TextBox x:Name="OutputFileNameTextBox"
                                     Style="{StaticResource TextInputStyle}" />

                            <Separator Margin="0,22,0,20" />

                            <TextBlock Text="Formats"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#25302F" />
                            <TextBlock Style="{StaticResource LabelStyle}"
                                       Text="Multiple selections are exported in parallel on background tasks." />
                            <WrapPanel>
                                <CheckBox x:Name="TxtFormatCheckBox"
                                          Checked="FormatSelectionChanged"
                                          Unchecked="FormatSelectionChanged"
                                          Content="TXT"
                                          Style="{StaticResource FormatCheckBoxStyle}" />
                                <CheckBox x:Name="CsvFormatCheckBox"
                                          Checked="FormatSelectionChanged"
                                          Unchecked="FormatSelectionChanged"
                                          Content="CSV"
                                          Style="{StaticResource FormatCheckBoxStyle}" />
                                <CheckBox x:Name="JsonFormatCheckBox"
                                          Checked="FormatSelectionChanged"
                                          Unchecked="FormatSelectionChanged"
                                          Content="JSON"
                                          Style="{StaticResource FormatCheckBoxStyle}" />
                                <CheckBox x:Name="XlsxFormatCheckBox"
                                          Checked="FormatSelectionChanged"
                                          Unchecked="FormatSelectionChanged"
                                          Content="XLSX"
                                          Style="{StaticResource FormatCheckBoxStyle}" />
                            </WrapPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ScanButton"
                                        Grid.Column="0"
                                        Click="ScanButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Scan Library" />

                                <Button x:Name="ExportButton"
                                        Grid.Column="2"
                                        Click="ExportButton_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Export Active Tab" />
                            </Grid>
                        </StackPanel>

                        <Border Margin="0,22,0,0"
                                Padding="16"
                                CornerRadius="16"
                                Background="#FFF9F1"
                                BorderBrush="#D9C8B3"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Activity"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#25302F" />
                                <ProgressBar x:Name="BusyProgressBar"
                                             Margin="0,12,0,0"
                                             Height="12"
                                             IsIndeterminate="True"
                                             Visibility="Collapsed" />
                                <TextBlock x:Name="StatusTextBlock"
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="#394443"
                                           Text="Select a source folder and scan the library." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0"
                                Padding="16"
                                CornerRadius="16"
                                Background="#FFF9F1"
                                BorderBrush="#D9C8B3"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Exported Files"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#25302F" />
                                <ListBox x:Name="ExportedFilesListBox"
                                         Margin="0,12,0,0"
                                         MinHeight="140"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#394443" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Library Results"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#25302F" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="#5E625C"
                                   Text="Scan once, switch between Movies and TV Shows, and export the active tab." />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="18"
                            CornerRadius="18"
                            Background="#FFF9F1"
                            BorderBrush="#D9C8B3"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0">
                                <TextBlock Text="Search"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#25302F" />
                                <TextBox x:Name="SearchTextBox"
                                         Margin="0,10,0,0"
                                         Padding="12,9"
                                         FontSize="14"
                                         Background="#FFFDF9"
                                         BorderBrush="#CDB9A3"
                                         BorderThickness="1"
                                         TextChanged="SearchTextBox_TextChanged" />
                            </StackPanel>

                            <Button x:Name="ClearFiltersButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="18,24,0,0"
                                    Click="ClearFiltersButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Clear Filters" />

                            <StackPanel Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,16,0,0">
                                <TextBlock Text="Resolution Availability"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#25302F" />
                                <WrapPanel Margin="0,10,0,0">
                                    <CheckBox x:Name="PalFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="576p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                    <CheckBox x:Name="HdFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="720p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                    <CheckBox x:Name="FullHdFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="1080p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                    <CheckBox x:Name="QuadHdFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="1440p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                    <CheckBox x:Name="Uhd4kFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="2160p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                    <CheckBox x:Name="Uhd8kFilterCheckBox"
                                              Checked="ResultFilterChanged"
                                              Unchecked="ResultFilterChanged"
                                              Content="4320p"
                                              Style="{StaticResource FilterChipCheckBoxStyle}" />
                                </WrapPanel>
                                <TextBlock x:Name="FilterSummaryTextBlock"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="#5E625C"
                                           Text="Showing all scanned results." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl x:Name="ResultsTabControl"
                                Grid.Row="4">
                        <TabItem x:Name="MoviesTabItem"
                                 Header="Movies">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Movies"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="MovieCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Resolution Entries"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="MovieResolutionCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <DataGrid x:Name="MoviesDataGrid"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          CanUserResizeRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="0"
                                          Background="{StaticResource TableBrush}"
                                          RowBackground="#FFFDF9"
                                          AlternatingRowBackground="#F5EFE5"
                                          HorizontalGridLinesBrush="#E1D4C6"
                                          VerticalGridLinesBrush="#E1D4C6"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Title"
                                                            Binding="{Binding Name}"
                                                            Width="2.4*" />
                                        <DataGridTextColumn Header="Year"
                                                            Binding="{Binding Year}"
                                                            Width="0.7*" />
                                        <DataGridTextColumn Header="IMDb"
                                                            Binding="{Binding ImdbId}"
                                                            Width="1.2*" />
                                        <DataGridTextColumn Header="TMDb"
                                                            Binding="{Binding TmdbId}"
                                                            Width="1*" />
                                        <DataGridTemplateColumn Header="Availability"
                                                                Width="1.9*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ItemsControl ItemsSource="{Binding ResolutionBadges}"
                                                                  ItemTemplate="{StaticResource ResolutionBadgeTemplate}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="TvShowsTabItem"
                                 Header="TV Shows">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="TV Shows"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="TvShowCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Seasons"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="TvSeasonCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Video Files"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="TvEpisodeCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="6"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Resolution Entries"
                                                       Style="{StaticResource SummaryLabelStyle}" />
                                            <TextBlock x:Name="TvResolutionCountTextBlock"
                                                       Style="{StaticResource SummaryValueStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.8*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="1.15*" />
                                    </Grid.ColumnDefinitions>

                                    <DataGrid x:Name="TvShowsDataGrid"
                                              Grid.Column="0"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserReorderColumns="False"
                                              CanUserResizeRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              BorderThickness="0"
                                              Background="{StaticResource TableBrush}"
                                              RowBackground="#FFFDF9"
                                              AlternatingRowBackground="#F5EFE5"
                                              HorizontalGridLinesBrush="#E1D4C6"
                                              VerticalGridLinesBrush="#E1D4C6"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              SelectionChanged="TvShowsDataGrid_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Title"
                                                                Binding="{Binding Name}"
                                                                Width="2.2*" />
                                            <DataGridTextColumn Header="Year"
                                                                Binding="{Binding Year}"
                                                                Width="0.7*" />
                                            <DataGridTextColumn Header="Seasons"
                                                                Binding="{Binding SeasonCount}"
                                                                Width="0.8*" />
                                            <DataGridTextColumn Header="Files"
                                                                Binding="{Binding EpisodeCount}"
                                                                Width="0.8*" />
                                            <DataGridTemplateColumn Header="Availability"
                                                                    Width="1.8*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ItemsControl ItemsSource="{Binding ResolutionBadges}"
                                                                      ItemTemplate="{StaticResource ResolutionBadgeTemplate}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Inspection"
                                                                    Width="1.4*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <Border Padding="10,4"
                                                                    Background="{Binding InspectionBackgroundBrush}"
                                                                    BorderBrush="{Binding InspectionBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="999">
                                                                <TextBlock Text="{Binding InspectionStatus}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding InspectionForegroundBrush}" />
                                                            </Border>
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Text="{Binding InspectionSummary}"
                                                                       FontSize="12"
                                                                       Foreground="#5E625C"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border Grid.Column="2"
                                            Padding="18"
                                            CornerRadius="18"
                                            Background="#FFF9F1"
                                            BorderBrush="#D9C8B3"
                                            BorderThickness="1">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Show Inspection"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="#25302F" />
                                                <TextBlock x:Name="SelectedShowTitleTextBlock"
                                                           Margin="0,10,0,0"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="#25302F"
                                                           Text="Select a TV show" />
                                                <TextBlock x:Name="SelectedShowMetadataTextBlock"
                                                           Margin="0,6,0,0"
                                                           FontSize="13"
                                                           Foreground="#5E625C"
                                                           TextWrapping="Wrap"
                                                           Text="Season and episode coverage will appear here." />

                                                <Border x:Name="SelectedShowStatusBorder"
                                                        Margin="0,18,0,0"
                                                        Padding="12,10"
                                                        Background="#EEE5D7"
                                                        BorderBrush="#D0C0AA"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <StackPanel>
                                                        <TextBlock x:Name="SelectedShowStatusTextBlock"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#5E625C"
                                                                   Text="No show selected" />
                                                        <TextBlock x:Name="SelectedShowSummaryTextBlock"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#5E625C"
                                                                   TextWrapping="Wrap"
                                                                   Text="Pick a row in the TV Shows table to inspect season gaps and episode coverage." />
                                                        <TextBlock x:Name="SelectedShowDiagnosticsTextBlock"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#6C6D68"
                                                                   TextWrapping="Wrap"
                                                                   Text="" />
                                                    </StackPanel>
                                                </Border>

                                                <WrapPanel Margin="0,18,0,0">
                                                    <Border Margin="0,0,12,12"
                                                            Padding="14"
                                                            CornerRadius="14"
                                                            Background="#FFFDF9"
                                                            BorderBrush="#D9C8B3"
                                                            BorderThickness="1">
                                                        <StackPanel Width="98">
                                                            <TextBlock Text="Indexed"
                                                                       Style="{StaticResource SummaryLabelStyle}" />
                                                            <TextBlock x:Name="SelectedShowIndexedEpisodesTextBlock"
                                                                       FontSize="24"
                                                                       FontWeight="Bold"
                                                                       Foreground="#25302F"
                                                                       Text="0" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,0,12,12"
                                                            Padding="14"
                                                            CornerRadius="14"
                                                            Background="#FFFDF9"
                                                            BorderBrush="#D9C8B3"
                                                            BorderThickness="1">
                                                        <StackPanel Width="98">
                                                            <TextBlock Text="Missing"
                                                                       Style="{StaticResource SummaryLabelStyle}" />
                                                            <TextBlock x:Name="SelectedShowMissingEpisodesTextBlock"
                                                                       FontSize="24"
                                                                       FontWeight="Bold"
                                                                       Foreground="#25302F"
                                                                       Text="0" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,0,12,12"
                                                            Padding="14"
                                                            CornerRadius="14"
                                                            Background="#FFFDF9"
                                                            BorderBrush="#D9C8B3"
                                                            BorderThickness="1">
                                                        <StackPanel Width="98">
                                                            <TextBlock Text="Duplicates"
                                                                       Style="{StaticResource SummaryLabelStyle}" />
                                                            <TextBlock x:Name="SelectedShowDuplicateEpisodesTextBlock"
                                                                       FontSize="24"
                                                                       FontWeight="Bold"
                                                                       Foreground="#25302F"
                                                                       Text="0" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,0,0,12"
                                                            Padding="14"
                                                            CornerRadius="14"
                                                            Background="#FFFDF9"
                                                            BorderBrush="#D9C8B3"
                                                            BorderThickness="1">
                                                        <StackPanel Width="110">
                                                            <TextBlock Text="Unparsed Files"
                                                                       Style="{StaticResource SummaryLabelStyle}" />
                                                            <TextBlock x:Name="SelectedShowUnparsedFilesTextBlock"
                                                                       FontSize="24"
                                                                       FontWeight="Bold"
                                                                       Foreground="#25302F"
                                                                       Text="0" />
                                                        </StackPanel>
                                                    </Border>
                                                </WrapPanel>

                                                <TextBlock Margin="0,6,0,8"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#25302F"
                                                           Text="Available Resolutions" />
                                                <ItemsControl x:Name="SelectedShowResolutionItemsControl"
                                                              ItemTemplate="{StaticResource ResolutionBadgeTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>

                                                <TextBlock Margin="0,18,0,8"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#25302F"
                                                           Text="Season Breakdown" />
                                                <ItemsControl x:Name="SelectedShowSeasonItemsControl"
                                                              ItemTemplate="{StaticResource SeasonInspectionTemplate}" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
